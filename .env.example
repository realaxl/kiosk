# Server Configuration
PORT=5000

# Database Configuration
DB_NAME=db.sqlite

# Admin Configuration
ADMIN_PASSWORD="change-the-secret"

# Event Configuration
EVENT="TEST EVENT 2026-05-10"

# UI Configuration
# Set to true for full-width containers, false for limited-width containers
FULL_WIDTH=false

# Admin Configuration
# Set to true to show admin button in main gallery
ALLOW_ADMIN=true

# Slideshow Configuration
# Delay between slides in seconds (default: 7)
SLIDESHOW_DELAY=7
# Set to true to show products in random order (default: false)
SLIDESHOW_ORDER_RANDOM=false